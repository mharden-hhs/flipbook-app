// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Flipbook {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  pageCount   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String
  isActive    Boolean  @default(true)
  viewCount   Int      @default(0)
  pagesDir    String
  // R2 storage: comma-separated list of page URLs (empty = use local filesystem)
  pageUrls    String   @default("")
}
