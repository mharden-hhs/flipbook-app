// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Flipbook {
  id        String   @id @default(cuid())
  slug      String   @unique // short public URL token e.g. "xk9m2"
  title     String
  pageCount Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String // Google email of admin who created it
  isActive  Boolean  @default(true)
  viewCount Int      @default(0)
  pagesDir  String // path/key to folder of page images in storage
}
